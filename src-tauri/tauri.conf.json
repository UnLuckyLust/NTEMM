{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NTEMM",
  "version": "1.3.1",
  "identifier": "unluckylust.ntemm",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NTEMM",
        "width": 1200,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 650,
        "center": true,
        "visible": false,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/icons/*.ico",
      "resources/binaries/7z.exe",
      "resources/binaries/7z.dll",
      "resources/loader/loader.asi",
      "resources/loader/loader.dll",
      "resources/loader/subloader.dll",
      "resources/mods/anticensor/Anticensor.asi",
      "resources/mods/Hide_UID/Hide_UID_P.pak",
      "resources/mods/Hide_UID/Hide_UID_P.ucas",
      "resources/mods/Hide_UID/Hide_UID_P.utoc"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwQTMxMkQ0NUI2Q0U0RjEKUldUeDVHeGIxQktqSUREbVVxWDN5R2ZwcE9rMG12YndjdERpQld2Tm1VWHFtMnZnNmFjZXdFRXIK",
      "endpoints": [
        "https://raw.githubusercontent.com/UnLuckyLust/NTEMM/main/public/changelog/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}